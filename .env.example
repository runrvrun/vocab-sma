# Prisma Postgres connection string
# Get this from your Prisma dashboard: https://console.prisma.io
# Format: prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY_HERE"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Your production URL (used by NextAuth for callbacks on Vercel)
NEXTAUTH_URL="https://your-app.vercel.app"
